# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=fsp_user
POSTGRES_PASSWORD=fsp_secret
POSTGRES_DB=fsplatform

# ── Database URLs (auto-constructed in docker-compose) ─
DATABASE_URL=postgresql+asyncpg://fsp_user:fsp_secret@localhost:5434/fsplatform
DATABASE_URL_SYNC=postgresql://fsp_user:fsp_secret@localhost:5434/fsplatform

# ── Qdrant ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6336
# Qdrant Cloud API key (leave empty for local/self-hosted Qdrant)
QDRANT_API_KEY=

# ── LLM Provider (pick one: anthropic | openai | groq | openrouter)
LLM_PROVIDER=anthropic

# ── API Keys (set the one matching your LLM_PROVIDER) ──
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Model Config ──────────────────────────────────────
# Primary LLM model — examples per provider:
#   anthropic:   claude-sonnet-4-20250514
#   openai:      gpt-4o-mini
#   groq:        llama-3.3-70b-versatile
#   openrouter:  anthropic/claude-sonnet-4-20250514
PRIMARY_MODEL=claude-sonnet-4-20250514
# Role-specific models (only used when LLM_PROVIDER=openrouter)
#   reasoning: debate agents, contradiction/dependency analysis
#   build:     task decomposition, test cases, impact analysis
#   longcontext: refinement rewrites, reverse FS with large docs
#   fallback:  backup if primary fails
REASONING_MODEL=deepseek/deepseek-v3.2-speciale
BUILD_MODEL=minimax/minimax-m2.7
LONGCONTEXT_MODEL=google/gemini-3-flash-preview
FALLBACK_MODEL=deepseek/deepseek-v3.2

# Best general-purpose + fast primary workhorse
#PRIMARY_MODEL=anthropic/claude-sonnet-4-6
# Best deep reasoner on the planet right now
#REASONING_MODEL=anthropic/claude-opus-4-6
# Best for agentic build tasks, repo-level coding
#BUILD_MODEL=anthropic/claude-opus-4-6
# Only model with 2M context + best multimodal (video/audio/docs)
#LONGCONTEXT_MODEL=google/gemini-3.1-pro-preview
# Fast, smart, cheap safety net
#FALLBACK_MODEL=google/gemini-3-flash-preview

# ── Embedding Provider (pick one: openai | groq | openrouter)
EMBEDDING_PROVIDER=openai

# Embedding model — examples per provider:
#   openai:      text-embedding-3-small
#   groq:        text-embedding-3-small
#   openrouter:  openai/text-embedding-3-small
EMBEDDING_MODEL=text-embedding-3-small

# ── Tool orchestration (0.4.0: always on, strict, no fallback) ────────
# Orchestration is now mandatory. Every LLM call routes through the
# provider registry; there is no feature flag and no silent fallback
# to Direct API. The registry maps:
#   llm_provider=api          → Direct API client (OpenRouter / Anthropic / …)
#   llm_provider=claude_code  → Claude Code CLI subprocess
#   llm_provider=cursor       → paste-per-action CursorTask flow (no server-side LLM call)
# The previously-removed flags ORCHESTRATION_ENABLED, ORCHESTRATION_STRICT_LLM,
# CURSOR_LLM_REQUEST_TIMEOUT_SEC, CURSOR_WORKER_TTL_SEC,
# CURSOR_WORKER_PRESENCE_WAIT_SEC and CURSOR_QUEUE_CLAIM_BATCH are gone —
# if you see them in an older env file, delete them.
#
# Claude Code CLI binary for llm_provider=claude_code (install + auth locally).
CLAUDE_CODE_CLI_PATH=claude
# Per-call LLM timeout in seconds (applies to direct + orchestrated clients).
LLM_TIMEOUT_S=120
# Retry attempts on transient LLM errors (network / 5xx).
LLM_RETRY_ATTEMPTS=3
# Backend URL the server uses to reach itself. Defaults to
# http://localhost:8000. Override when running behind a reverse proxy or
# inside a container network.
BACKEND_SELF_URL=http://localhost:8000
# TTL for a paste-per-action CursorTask (seconds). After this window a
# PENDING / CLAIMED row is marked EXPIRED by the sweeper so the UI stops
# polling. Default 900 (15 minutes).
CURSOR_TASK_TTL_SEC=900

# ── App ───────────────────────────────────────────────
# local | production | render
ENVIRONMENT=local
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20
# Reverse FS hybrid large-archive mode
REVERSE_LARGE_UPLOAD_ENABLED=true
REVERSE_MAX_ARCHIVE_SIZE_MB=300
REVERSE_MAX_UNCOMPRESSED_MB=900
REVERSE_MAX_ARCHIVE_FILES=25000
# Reverse parser/generation tuning
REVERSE_INCLUDE_EXTENSIONS=.py,.js,.ts,.jsx,.tsx,.java,.go
REVERSE_SKIP_DIRS_EXTRA=
REVERSE_SKIP_FILES_EXTRA=
REVERSE_MAX_FILE_SIZE_BYTES=500000
REVERSE_MAX_FILES_TO_PARSE=2500
REVERSE_TOP_FILES_INITIAL=60
REVERSE_TOP_FILES_MAX=220
REVERSE_MAX_ENTITIES_PER_FILE=40
REVERSE_MAX_CODE_EXCERPT_CHARS=12000
REVERSE_MIN_ACCEPTABLE_FLOWS=4
# MCP monitoring + safety gates
MCP_MONITORING_ENABLED=true
MCP_REQUIRE_ZERO_HIGH_AMBIGUITIES=true
MCP_MIN_QUALITY_SCORE=90
MCP_REQUIRE_TRACEABILITY=true
MCP_DRY_RUN_DEFAULT=false
# Comma-separated origins for CORS (set your Vercel URL in production)
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://frontend:3000

# ── Upstash Redis (optional / future use) ─────────────
REDIS_URL=

# ── JIRA (optional — simulated mode if not set) ───────
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_jira_token
JIRA_PROJECT_KEY=FSP

# ── Confluence (optional — simulated mode if not set) ─
CONFLUENCE_URL=https://your-org.atlassian.net/wiki
CONFLUENCE_EMAIL=you@example.com
CONFLUENCE_API_TOKEN=your_confluence_token
CONFLUENCE_SPACE_KEY=FSP
